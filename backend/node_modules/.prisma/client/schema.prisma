generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                                    String         @id @default(cuid())
  email                                 String         @unique
  password                              String
  name                                  String
  role                                  String         @default("user")
  isActive                              Boolean        @default(true)
  isEmailVerified                       Boolean        @default(false)
  emailVerifyToken                      String?
  refreshToken                          String?
  resetPasswordToken                    String?
  resetPasswordExpires                  DateTime?
  lastLoginAt                           DateTime?
  avatarUrl                             String?
  themePreference                       String?        @default("light")
  notificationPreferences               Json?          @default("{}")
  createdAt                             DateTime       @default(now())
  updatedAt                             DateTime       @updatedAt
  analyses_analyses_approvedByIdTousers Analysis[]     @relation("analyses_approvedByIdTousers")
  analyses                              Analysis[]
  auditLogs                             AuditLog[]
  resumes                               Resume[]
  subscriptions                         subscriptions?

  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  passwordResets     PasswordReset[]

  @@map("users")
}

model Resume {
  id              String            @id @default(cuid())
  userId          String
  title           String
  fileUrl         String
  fileKey         String
  fileType        String
  fileSize        Int?
  targetRole      String?
  parsedData      Json?
  extractedText   String?
  isParsed        Boolean           @default(false)
  deletedAt       DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  analyses        Analysis[]
  certifications  certifications[]
  education       education[]
  experiences     experiences[]
  projects        projects[]
  resume_history  resume_history[]
  resume_versions resume_versions[]
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills          skills[]

  @@index([userId])
  @@map("resumes")
}

model Analysis {
  id                                 String         @id @default(cuid())
  userId                             String
  resumeId                           String
  targetRole                         String?
  atsScore                           Int?
  qualityScore                       Int?
  skillsMatch                        Json?
  missingKeywords                    Json?
  missingSkills                      Json?
  suggestionsData                    Json?
  rewriteSuggestions                 Json?
  createdAt                          DateTime       @default(now())
  approvedAt                         DateTime?
  approvedById                       String?
  domainExperience                   Int            @default(0)
  leadershipImpact                   Int            @default(0)
  optimizationCheck                  Json           @default("[]")
  status                             AnalysisStatus @default(PENDING)
  technicalProwess                   Int            @default(0)
  overallScore                       Int?
  formattingScore                    Int?
  keywordScore                       Int?
  readabilityScore                   Int?
  sectionCompleteness                Json?
  strengths                          Json?
  weaknesses                         Json?
  rawSuggestions                     Json?
  duplicateKeywords                  Json?
  keywordDensity                     Json?
  improvementSuggestions             Json?
  actionVerbScore                    Int?
  quantificationScore                Int?
  aiProvider                         String?
  aiModel                            String?
  processingTime                     Int?
  errorMessage                       String?
  ai_usage                           ai_usage?
  users_analyses_approvedByIdTousers User?          @relation("analyses_approvedByIdTousers", fields: [approvedById], references: [id])
  resume                             Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  user                               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ats_scores                         ats_scores?
  keywords                           keywords[]
  suggestions                        suggestions[]

  @@index([approvedById])
  @@index([resumeId])
  @@index([userId])
  @@map("analyses")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
  @@map("audit_logs")
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model EmailVerification {
  id         String    @id @default(cuid())
  userId     String    @unique
  tokenHash  String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("email_verifications")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_resets")
}

model ai_usage {
  id             String    @id
  userId         String
  analysisId     String?   @unique
  feature        String
  totalTokens    Int       @default(0)
  model          String
  provider       String
  processingTime Int
  createdAt      DateTime  @default(now())
  analyses       Analysis? @relation(fields: [analysisId], references: [id])

  @@index([analysisId])
  @@index([userId])
}

model ats_scores {
  id                 String   @id
  resumeId           String   @unique
  analysisId         String   @unique
  overallScore       Int
  formattingScore    Int
  keywordScore       Int
  readabilityScore   Int
  sectionScore       Int
  roleRelevanceScore Int
  experienceScore    Int
  educationScore     Int
  skillsScore        Int
  projectScore       Int
  certificationScore Int
  breakdown          Json
  createdAt          DateTime @default(now())
  analyses           Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

model certifications {
  id         String  @id
  resumeId   String
  name       String
  issuer     String?
  issueDate  String?
  expiryDate String?
  credential String?
  resumes    Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model education {
  id          String  @id
  resumeId    String
  institution String
  degree      String
  field       String?
  startDate   String?
  endDate     String?
  gpa         String?
  resumes     Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model experiences {
  id          String  @id
  resumeId    String
  company     String
  position    String
  startDate   String?
  endDate     String?
  current     Boolean @default(false)
  description String?
  resumes     Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model keywords {
  id          String   @id
  resumeId    String
  analysisId  String
  keyword     String
  category    String
  density     Float
  frequency   Int
  isMissing   Boolean  @default(false)
  isDuplicate Boolean  @default(false)
  relevance   Float
  analyses    Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([resumeId])
}

model projects {
  id           String  @id
  resumeId     String
  name         String
  description  String?
  technologies String?
  url          String?
  resumes      Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model resume_history {
  id        String   @id
  userId    String?
  resumeId  String
  action    String
  details   Json?
  createdAt DateTime @default(now())
  resumes   Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([resumeId])
}

model resume_versions {
  id            String   @id
  resumeId      String
  versionNumber Int
  fileUrl       String
  fileKey       String
  fileType      String
  fileSize      Int?
  createdAt     DateTime @default(now())
  resumes       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model skills {
  id       String @id
  resumeId String
  name     String
  category String @default("parsed")
  resumes  Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model subscriptions {
  id        String    @id
  userId    String    @unique
  tier      String    @default("FREE")
  status    String    @default("active")
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime
  users     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model suggestions {
  id         String   @id
  resumeId   String
  analysisId String
  category   String
  priority   String
  original   String
  suggestion String
  reasoning  String?
  createdAt  DateTime @default(now())
  analyses   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
  @@index([resumeId])
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  APPROVED
}
